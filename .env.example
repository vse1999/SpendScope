# ============================================
# SpendScope Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!

# ============================================
# Database (Neon PostgreSQL)
# ============================================
# Get your connection string from: https://console.neon.tech/
# Format: postgresql://user:password@host/db?sslmode=verify-full
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/db?sslmode=verify-full"

# ============================================
# NextAuth.js Configuration
# ============================================
# Development URL
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Production URL (update when deploying)
# NEXTAUTH_URL="https://yourdomain.com"

# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-min-32-characters-long"

# ============================================
# OAuth Providers
# ============================================
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================
# Stripe (Optional - for subscriptions)
# ============================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Billing feature flag (required to show/enable billing flows)
NEXT_PUBLIC_ENABLE_BILLING="false"

# Safety guard: keep false for project/staging unless you intentionally use live keys
ALLOW_LIVE_STRIPE_KEYS="false"

# Price IDs from Stripe Dashboard > Products
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."

# Debug-only billing reset control (non-production only)
# Set both flags to "true" only in local/staging test environments
ALLOW_BILLING_RESET="false"
NEXT_PUBLIC_ALLOW_BILLING_RESET="false"

# ============================================
# Test/E2E Endpoints (non-production only)
# ============================================
# Enables /api/test-login, /api/test-logout, /api/rate-limit-test in non-production
ENABLE_TEST_ENDPOINTS="false"

# Additional gate for /api/test-login bypass flow
E2E_LOGIN_BYPASS="false"

# ============================================
# Team Invitations Email (Resend)
# ============================================
RESEND_API_KEY="re_..."
INVITATION_FROM_EMAIL="SpendScope <no-reply@yourdomain.com>"

# ============================================
# Rate Limiting (Upstash Redis)
# ============================================
# Get your credentials from: https://console.upstash.com/
# Optional - falls back to memory-based rate limiting if not configured
# Note: Memory-based rate limiting is NOT suitable for production!
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# ============================================
# Sentry Error Tracking
# ============================================
# Get your DSN from: https://sentry.io/settings/projects/
# Sign up at https://sentry.io/signup/ (free tier available)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"
SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"

# Optional: Organization and project for source maps (CI/CD only)
SENTRY_ORG="your-org-name"
SENTRY_PROJECT="spendscope"
# SENTRY_AUTH_TOKEN="your-auth-token"  # Only in CI/CD, never commit!

# Optional: include user-identifying data in Sentry events
SENTRY_SEND_DEFAULT_PII="false"

# Explicit Sentry runtime enable flags (recommended to keep false in local by default)
NEXT_PUBLIC_SENTRY_ENABLED="false"
SENTRY_ENABLED="false"
