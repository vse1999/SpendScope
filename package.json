{
  "name": "spendscope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:any": "node scripts/check-explicit-any.mjs",
    "postinstall": "prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --runInBand --coverage",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "smoke:deploy": "node scripts/smoke-checks.mjs",
    "deploy:check": "node scripts/deploy-check.mjs",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhooks",
    "stripe:listen:secret": "stripe listen --forward-to localhost:3000/api/stripe/webhooks --print-secret",
    "stripe:trigger:checkout": "stripe trigger checkout.session.completed",
    "seed:demo": "ts-node --project tsconfig.scripts.json scripts/seed-demo.ts",
    "seed:demo:reset": "ts-node --project tsconfig.scripts.json scripts/reset-demo.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@sentry/nextjs": "^10.38.0",
    "@upstash/redis": "^1.36.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.2.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
